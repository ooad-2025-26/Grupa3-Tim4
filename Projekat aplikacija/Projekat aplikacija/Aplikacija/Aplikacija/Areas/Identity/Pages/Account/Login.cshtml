@page
@model LoginModel

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow p-4">
            <h2 class="text-center mb-3">Login</h2>
            <p class="text-center text-muted">Sign in to your GameHub account</p>

            <form id="account" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="Password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="form-check mb-3">
                    <input class="form-check-input" asp-for="Input.RememberMe" />
                    <label class="form-check-label" asp-for="Input.RememberMe">
                        Remember me
                    </label>
                </div>

                <button id="login-submit" type="submit" class="w-100 btn btn-primary btn-lg">
                    Login
                </button>

                <div class="text-center mt-3">
                    <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">
                        Create new account
                    </a>
                </div>
                <div class="alert alert-info mt-3 text-center">
                    If you forgot your password, please contact an administrator.
                </div>
             
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}