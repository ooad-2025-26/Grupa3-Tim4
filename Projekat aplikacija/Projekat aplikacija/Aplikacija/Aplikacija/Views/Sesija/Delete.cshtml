@model Aplikacija.Models.Sesija

@{
    ViewData["Title"] = "Delete Session";

    double cijenaPoSatu = 0;

    if (Model.Uredjaj is PC pc)
    {
        cijenaPoSatu = pc.CijenaPoSatu;
    }
    else if (Model.Uredjaj is PlayStation ps)
    {
        cijenaPoSatu = ps.CijenaPoSatu;
    }
    else if (Model.Uredjaj is XBox xbox)
    {
        cijenaPoSatu = xbox.CijenaPoSatu;
    }

    var trajanje = Model.VrijemeZavrsetka - Model.VrijemePocetka;
    var cijena = trajanje.TotalHours * cijenaPoSatu;
}

<h2>Delete Session</h2>

<div class="alert alert-danger" style="max-width: 700px;">
    Are you sure you want to delete this session?
</div>

<div class="card p-4" style="max-width: 700px;">
    <dl class="row mb-0">
        <dt class="col-sm-4">Start time</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.VrijemePocetka)</dd>

        <dt class="col-sm-4">End time</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.VrijemeZavrsetka)</dd>

        <dt class="col-sm-4">Status</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Status)</dd>

        <dt class="col-sm-4">User</dt>
        <dd class="col-sm-8">
            @(Model.AnonimniGost ? "Anonymous Guest" : Model.Korisnik?.Email)
        </dd>

        <dt class="col-sm-4">Device</dt>
        <dd class="col-sm-8">@Model.Uredjaj?.TipUredjaja</dd>

        <dt class="col-sm-4">Price</dt>
        <dd class="col-sm-8">@cijena.ToString("0.00") KM</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary ms-2">
        Back to List
    </a>
</form>