@model IEnumerable<Aplikacija.Models.Sesija>

@{
    ViewData["Title"] = "Sessions";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Sessions</h2>
            <p class="text-muted mb-0">View, manage and end active gaming sessions.</p>
        </div>

        <a asp-action="Create" class="btn btn-primary">
            + Create New
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Session List</h5>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.VrijemePocetka)</th>
                        <th>@Html.DisplayNameFor(model => model.VrijemeZavrsetka)</th>
                        <th>@Html.DisplayNameFor(model => model.Status)</th>
                        <th>User</th>
                        <th>Device</th>
                        <th>Price</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        double cijenaPoSatu = 0;

                        if (item.Uredjaj is PC pc)
                        {
                            cijenaPoSatu = pc.CijenaPoSatu;
                        }
                        else if (item.Uredjaj is PlayStation ps)
                        {
                            cijenaPoSatu = ps.CijenaPoSatu;
                        }
                        else if (item.Uredjaj is XBox xbox)
                        {
                            cijenaPoSatu = xbox.CijenaPoSatu;
                        }

                        var trajanje = item.VrijemeZavrsetka - item.VrijemePocetka;
                        var cijena = trajanje.TotalHours * cijenaPoSatu;

                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.VrijemePocetka)</td>
                            <td>@Html.DisplayFor(modelItem => item.VrijemeZavrsetka)</td>

                            <td>
                                @if (item.Status == StatusSesije.Aktivna)
                                {
                                    <span class="badge bg-success">Aktivna</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@item.Status</span>
                                }
                            </td>

                            <td>
                                @(item.AnonimniGost ? "Anonymous Guest" : item.Korisnik?.Email)
                            </td>

                            <td>@item.Uredjaj?.TipUredjaja</td>

                            <td>
                                <span class="badge bg-info text-dark fs-6">
                                    @cijena.ToString("0.00") KM
                                </span>
                            </td>

                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                                    Details
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                    Delete
                                </a>

                                @if (item.Status == StatusSesije.Aktivna)
                                {
                                    <form asp-action="EndSession" method="post" class="d-inline">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />

                                        <button type="submit" class="btn btn-dark btn-sm">
                                            End Session
                                        </button>
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>