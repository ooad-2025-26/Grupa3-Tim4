@model Aplikacija.Models.Korisnik

@{
    ViewData["Title"] = "Edit User";
}

<div class="container mt-4">

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h3 class="mb-0">Edit User</h3>
        </div>

        <div class="card-body">

            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <input type="hidden" asp-for="Id" />

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="Ime" class="form-label">First Name</label>
                        <input asp-for="Ime" class="form-control" />
                        <span asp-validation-for="Ime" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="Prezime" class="form-label">Last Name</label>
                        <input asp-for="Prezime" class="form-control" />
                        <span asp-validation-for="Prezime" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Email" class="form-label">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="form-check mb-4">
                    <input asp-for="ClanarinaAktivna" class="form-check-input" />
                    <label asp-for="ClanarinaAktivna" class="form-check-label">
                        Membership active
                    </label>
                </div>

                <hr />

                <button type="submit" class="btn btn-primary">
                    Save Changes
                </button>

                <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-secondary">
                    Cancel
                </a>

            </form>

        </div>
    </div>

</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}