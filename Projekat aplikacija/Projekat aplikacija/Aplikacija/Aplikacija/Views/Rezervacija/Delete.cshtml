@model Aplikacija.Models.Rezervacija

@{
    ViewData["Title"] = "Delete Reservation";
}

<h2>Delete Reservation</h2>

<div class="alert alert-danger" style="max-width: 650px;">
    Are you sure you want to delete this reservation?
</div>

<div class="card p-4" style="max-width: 650px;">
    <dl class="row mb-0">
        <dt class="col-sm-4">Start time</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.VrijemeOd)</dd>

        <dt class="col-sm-4">End time</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.VrijemeDo)</dd>

        <dt class="col-sm-4">Status</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Status)</dd>

        <dt class="col-sm-4">User</dt>
        <dd class="col-sm-8">@Model.Korisnik?.Email</dd>

        <dt class="col-sm-4">Device</dt>
        <dd class="col-sm-8">@Model.Uredjaj?.TipUredjaja</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary ms-2">
        Back to List
    </a>
</form>