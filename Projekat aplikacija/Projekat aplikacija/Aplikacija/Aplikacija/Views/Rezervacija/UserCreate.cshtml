    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
    ViewData["Title"] = "Add Reservation";

    DateTime odabraniDatum = ViewBag.OdabraniDatum;
    List<int> zauzetiSati = ViewBag.ZauzetiSati;
}

<h2>Add Reservation</h2>

<form asp-action="UserCreate" method="get" class="mb-4">
    <label>Choose date:</label>
    <input type="date"
           name="datum"
           value="@odabraniDatum.ToString("yyyy-MM-dd")"
           class="form-control"
           style="max-width: 250px;"
           onchange="this.form.submit()" />
</form>

<div class="row">
    @for (int sat = 9; sat <= 21; sat++)
    {
        bool zauzeto = zauzetiSati.Contains(sat);

        <div class="col-md-3 mb-3">
            <form asp-action="UserCreate" method="post">
                @Html.AntiForgeryToken()

                <input type="hidden" name="datum" value="@odabraniDatum.ToString("yyyy-MM-dd")" />
                <input type="hidden" name="sat" value="@sat" />

                <button type="submit"
                        class="btn w-100 @(zauzeto ? "btn-secondary" : "btn-success")"
                    @(zauzeto ? "disabled" : "")>
                    @sat:00 - @(sat + 1):00
                    <br />
                    @(zauzeto ? "Zauzeto" : "Slobodno")
                </button>
            </form>
        </div>
    }
</div>
