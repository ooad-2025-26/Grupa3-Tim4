@model IEnumerable<Aplikacija.Models.Placanje>

@{
    ViewData["Title"] = "Payment History";
}

<div class="container mt-4">

    <div class="mb-4">
        <h2 class="mb-1">Payment History</h2>
        <p class="text-muted mb-0">Review payments, users and related reservations.</p>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Payments</h5>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Amount</th>
                        <th>Payment Method</th>
                        <th>Payment Date</th>
                        <th>User</th>
                        <th>Reservation</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <span class="badge bg-success fs-6">
                                    @item.Iznos.ToString("0.00") KM
                                </span>
                            </td>

                            <td>@item.MetodaPlacanja</td>
                            <td>@item.DatumPlacanja.ToString("dd.MM.yyyy HH:mm")</td>
                            <td>@item.Korisnik?.Email</td>

                            <td>
                                @if (item.Rezervacija != null)
                                {
                                    <span>
                                        @item.Rezervacija.VrijemeOd.ToString("dd.MM.yyyy HH:mm")
                                        -
                                        @item.Rezervacija.VrijemeDo.ToString("HH:mm")
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted">No reservation</span>
                                }
                            </td>

                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                                    Details
                                </a>

                                @if (User.IsInRole("Administrator"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                        Edit
                                    </a>

                                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                        Delete
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>