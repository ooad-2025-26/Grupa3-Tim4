@model Aplikacija.Models.Placanje

@{
    ViewData["Title"] = "Delete Payment";
}

<h2>Delete Payment</h2>

<div class="alert alert-danger" style="max-width: 700px;">
    Are you sure you want to delete this payment?
</div>

<div class="card p-4" style="max-width: 700px;">
    <dl class="row mb-0">
        <dt class="col-sm-4">Amount</dt>
        <dd class="col-sm-8">@Model.Iznos.ToString("0.00") KM</dd>

        <dt class="col-sm-4">Payment Method</dt>
        <dd class="col-sm-8">@Model.MetodaPlacanja</dd>

        <dt class="col-sm-4">Payment Date</dt>
        <dd class="col-sm-8">@Model.DatumPlacanja.ToString("dd.MM.yyyy HH:mm")</dd>

        <dt class="col-sm-4">User</dt>
        <dd class="col-sm-8">@Model.Korisnik?.Email</dd>

        <dt class="col-sm-4">Reservation</dt>
        <dd class="col-sm-8">
            @if (Model.Rezervacija != null)
            {
                <span>
                    @Model.Rezervacija.VrijemeOd.ToString("dd.MM.yyyy HH:mm")
                    -
                    @Model.Rezervacija.VrijemeDo.ToString("HH:mm")
                </span>
            }
            else
            {
                <span>No reservation</span>
            }
        </dd>
    </dl>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Delete
    </button>

    <a asp-action="Index" class="btn btn-secondary ms-2">
        Back to List
    </a>
</form>