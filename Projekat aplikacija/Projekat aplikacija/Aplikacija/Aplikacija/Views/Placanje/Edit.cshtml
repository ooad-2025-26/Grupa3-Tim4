@model Aplikacija.Models.Placanje

@{
    ViewData["Title"] = "Edit Payment";
}

<h2>Edit Payment</h2>

<div class="card p-4" style="max-width: 650px;">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

        <input type="hidden" asp-for="Id" />

        <div class="form-group mb-3">
            <label asp-for="Iznos" class="control-label">Amount</label>
            <input asp-for="Iznos" class="form-control" />
            <span asp-validation-for="Iznos" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="MetodaPlacanja" class="control-label">Payment Method</label>
            <select asp-for="MetodaPlacanja" class="form-control">
                <option value="Cash">Cash</option>
                <option value="Card">Card</option>
                <option value="LoyaltyPoints">Loyalty points</option>
            </select>
            <span asp-validation-for="MetodaPlacanja" class="text-danger"></span>
        </div>

        <div class="form-group mb-3">
            <label asp-for="KorisnikId" class="control-label">User</label>
            <select asp-for="KorisnikId" class="form-control" asp-items="ViewBag.KorisnikId"></select>
            <span asp-validation-for="KorisnikId" class="text-danger"></span>
        </div>

        <button type="submit" class="btn btn-primary">
            Save
        </button>

        <a asp-action="Index" class="btn btn-secondary ms-2">
            Back to List
        </a>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}