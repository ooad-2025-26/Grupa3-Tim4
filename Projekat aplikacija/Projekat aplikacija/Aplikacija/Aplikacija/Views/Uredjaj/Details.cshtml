@model Aplikacija.Models.Uredjaj

@{
    ViewData["Title"] = "Device Details";
}

<h2>Device Details</h2>

<div class="card p-4" style="max-width: 700px;">
    <dl class="row">

        <dt class="col-sm-4">Device Type</dt>
        <dd class="col-sm-8">@Model.TipUredjaja</dd>

        <dt class="col-sm-4">Device ID</dt>
        <dd class="col-sm-8">@Model.Id</dd>

        <dt class="col-sm-4">Status</dt>
        <dd class="col-sm-8">@Html.DisplayFor(model => model.Status)</dd>

        @if (Model is PC pc)
        {
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@pc.Naziv</dd>

            <dt class="col-sm-4">Model</dt>
            <dd class="col-sm-8">@pc.Model</dd>

            <dt class="col-sm-4">Price per Hour</dt>
            <dd class="col-sm-8">@pc.CijenaPoSatu.ToString("0.00") KM</dd>
        }

        @if (Model is PlayStation ps)
        {
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@ps.Naziv</dd>

            <dt class="col-sm-4">Price per Hour</dt>
            <dd class="col-sm-8">@ps.CijenaPoSatu.ToString("0.00") KM</dd>
        }

        @if (Model is XBox xbox)
        {
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@xbox.Naziv</dd>

            <dt class="col-sm-4">Price per Hour</dt>
            <dd class="col-sm-8">@xbox.CijenaPoSatu.ToString("0.00") KM</dd>
        }

    </dl>
</div>

<div class="mt-3">

    @if (User.IsInRole("Administrator"))
    {
        <a asp-action="Edit"
               asp-route-id="@Model.Id"
               class="btn btn-primary">
            Edit
        </a>
    }

    <a asp-action="Index"
           class="btn btn-secondary ms-2">
        Back
    </a>

</div>