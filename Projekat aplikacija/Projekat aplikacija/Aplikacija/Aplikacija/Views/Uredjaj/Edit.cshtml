@model Aplikacija.Models.Uredjaj
@using Aplikacija.Models

@{
    ViewData["Title"] = "Edit Device";
}

<h2>Edit Device</h2>

<div class="card p-4" style="max-width: 600px;">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()

        <input type="hidden" name="id" value="@Model.Id" />

        <div class="form-group mb-3">
            <label>Device Type</label>
            <input value="@Model.TipUredjaja" class="form-control" readonly />
        </div>

        <div class="form-group mb-3">
            <label>Name</label>
            <input value="@ViewBag.Naziv" class="form-control" readonly />
        </div>

        <div class="form-group mb-3">
            <label>Status</label>
            <select name="Status"
                    class="form-control"
                    asp-items="Html.GetEnumSelectList<StatusUredjaja>()">
            </select>
        </div>

        <div class="form-group mb-3">
            <label>Price per Hour</label>
            <input type="number"
                   step="0.01"
                   name="CijenaPoSatu"
                   value="@ViewBag.CijenaPoSatu"
                   class="form-control" />
        </div>

        <button type="submit" class="btn btn-primary">
            Save Changes
        </button>

        <a asp-action="Index" class="btn btn-secondary ms-2">
            Back
        </a>
    </form>
</div>