@model IEnumerable<Aplikacija.Models.PC>

@{
    ViewData["Title"] = "PC Devices";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">PC Devices</h2>
            <p class="text-muted mb-0">Manage PC devices, prices and device status.</p>
        </div>

        @if (User.IsInRole("Administrator"))
        {
            <a asp-action="Create" class="btn btn-primary">
                + Add PC
            </a>
        }
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">PC Device List</h5>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th>
                        <th>Price per Hour</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Naziv</td>

                            <td>
                                <span class="badge bg-info text-dark fs-6">
                                    @item.CijenaPoSatu.ToString("0.00") KM
                                </span>
                            </td>

                            <td>
                                @if (item.Status == StatusUredjaja.Neispravan)
                                {
                                    <span class="badge bg-danger">Neispravan</span>
                                }
                                else
                                {
                                    <span class="badge bg-success">@item.Status</span>
                                }
                            </td>

                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                                    Details
                                </a>

                                @if (User.IsInRole("Administrator"))
                                {
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                        Edit
                                    </a>
                                }

                                @if (item.Status == StatusUredjaja.Neispravan)
                                {
                                    <form asp-controller="Uredjaj"
                                          asp-action="VratiUUpotrebu"
                                          method="post"
                                          class="d-inline">
                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="id" value="@item.Id" />
                                        <input type="hidden" name="returnAction" value="PC" />

                                        <button type="submit" class="btn btn-success btn-sm">
                                            Return to Service
                                        </button>
                                    </form>
                                }
                                else
                                {
                                    <a asp-action="PrijaviKvar"
                                           asp-route-id="@item.Id"
                                           class="btn btn-danger btn-sm">
                                        Report Issue
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>