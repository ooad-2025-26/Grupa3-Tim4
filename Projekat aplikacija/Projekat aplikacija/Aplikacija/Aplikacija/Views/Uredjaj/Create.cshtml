@using Aplikacija.Models

@{
    ViewData["Title"] = "Create";
}

<h1>Dodaj uređaj</h1>

<hr />

<div class="row">
    <div class="col-md-4">
        <form asp-action="Create" method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <<div class="form-group mb-3">
                <label class="control-label">Vrsta uređaja</label>
                <select name="VrstaUredjaja" id="VrstaUredjaja" class="form-control">
                    <option value="">-- Izaberi vrstu --</option>
                    <option value="PC">PC</option>
                    <option value="PlayStation">PlayStation</option>
                    <option value="XBox">XBox</option>
                </select>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Status</label>
                <select name="Status" class="form-control" asp-items="Html.GetEnumSelectList<StatusUredjaja>()"></select>
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Naziv</label>
                <input name="Naziv" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label class="control-label">Cijena po satu</label>
                <input name="CijenaPoSatu" class="form-control" type="number" step="0.01" />
            </div>

            <div class="form-group mb-3" id="modelDiv" style="display:none;">
                <label class="control-label">Model PC-a</label>
                <input name="Model" class="form-control" />
                <small class="text-muted">Popunjava se samo za PC.</small>
            </div>

            <div class="form-group">
                <input type="submit" value="Dodaj uređaj" class="btn btn-primary" />
            </div>

        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Nazad na listu</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        document.getElementById("VrstaUredjaja").addEventListener("change", function () {

            var modelDiv = document.getElementById("modelDiv");

            if (this.value === "PC") {
                modelDiv.style.display = "block";
            } else {
                modelDiv.style.display = "none";
            }
        });
    </script>
}