@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model IEnumerable<Aplikacija.Models.XBox>

@{
    ViewData["Title"] = "XBox Devices";
}

<h1>XBox Devices</h1>
@if (User.IsInRole("Administrator"))
{
    <p>
        <a asp-action="Create">Add XBox</a>
    </p>
}
<th>Akcije</th>
<table class="table">
    <thead>
        <tr>
            <th>Naziv</th>
            <th>Cijena po satu</th>
            <th>Status</th>
            <th>Akcije</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Naziv</td>
                <td>@item.CijenaPoSatu</td>
                <td>@item.Status</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>

                    @if (User.IsInRole("Administrator"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    }

                    <a asp-action="PrijaviKvar" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Prijavi kvar</a>
                </td>
            </tr>
        }
    </tbody>
</table>
