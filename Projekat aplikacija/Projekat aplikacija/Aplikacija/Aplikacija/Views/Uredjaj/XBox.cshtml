@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@model IEnumerable<Aplikacija.Models.XBox>

@{
    ViewData["Title"] = "XBox Devices";
}

<h1>XBox Devices</h1>
@if (User.IsInRole("Administrator"))
{
    <p>
        <a asp-action="Create">Add XBox</a>
    </p>
}

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Price per Hour</th>
            <th>Status</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Naziv</td>
                <td>@item.CijenaPoSatu</td>
                <td>@Html.DisplayFor(modelItem => item.Status)</td>
                <td>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm">Details</a>

                    @if (User.IsInRole("Administrator"))
                    {
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Edit</a>
                    }

                    @if (item.Status == StatusUredjaja.Neispravan)
                    {
                        <form asp-controller="Uredjaj"
                              asp-action="VratiUUpotrebu"
                              method="post"
                              style="display:inline;">
                            @Html.AntiForgeryToken()

                            <input type="hidden" name="id" value="@item.Id" />
                            <input type="hidden" name="returnAction" value="XBox" />

                            <button type="submit" class="btn btn-success btn-sm">
                                Return to Service
                            </button>
                        </form>
                    }
                    else
                    {
                        <a asp-action="PrijaviKvar"
                               asp-route-id="@item.Id"
                               class="btn btn-danger btn-sm">
                            Report Issue
                        </a>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
