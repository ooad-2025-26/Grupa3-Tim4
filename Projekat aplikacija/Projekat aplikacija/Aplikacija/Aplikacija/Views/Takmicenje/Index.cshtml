@model IEnumerable<Aplikacija.Models.Takmicenje>

@{
    ViewData["Title"] = "Competitions";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="mb-1">Competitions</h2>
            <p class="text-muted mb-0">Manage tournaments and load competitions from external system.</p>
        </div>

        <div>
            <a asp-action="Create" class="btn btn-primary">
                + Create New
            </a>

            <a asp-action="UcitajIzVanjskogSistema" class="btn btn-success">
                Load Competitions
            </a>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">Competition List</h5>
        </div>

        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>@Html.DisplayNameFor(model => model.Naziv)</th>
                        <th>@Html.DisplayNameFor(model => model.Igra)</th>
                        <th>@Html.DisplayNameFor(model => model.Datum)</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@Html.DisplayFor(modelItem => item.Naziv)</td>
                            <td>@Html.DisplayFor(modelItem => item.Igra)</td>
                            <td>@Html.DisplayFor(modelItem => item.Datum)</td>

                            <td class="text-center">
                                <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-info btn-sm text-white">
                                    Details
                                </a>

                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                    Edit
                                </a>

                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                    Delete
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

</div>