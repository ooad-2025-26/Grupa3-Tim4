@{
    ViewData["Title"] = "Home";
}

@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
{
    <h2>Administrator Panel</h2>


    <div class="row">

        <div class="row">

            <div class="col-md-4 mb-3">
                <div class="card p-3 h-100">
                    <h4>Users</h4>
                    <p>Manage users, roles, memberships and loyalty points.</p>

                    <a asp-controller="Korisnik" asp-action="Index" class="btn btn-primary mb-2">
                        View Users
                    </a>

                    <a asp-controller="Korisnik" asp-action="Create" class="btn btn-outline-primary">
                        Add User
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card p-3 h-100">
                    <h4>Reservations</h4>
                    <p>View, create and manage user reservations.</p>

                    <a asp-controller="Rezervacija" asp-action="Index" class="btn btn-primary mb-2">
                        View Reservations
                    </a>

                    <a asp-controller="Rezervacija" asp-action="Create" class="btn btn-outline-primary">
                        Add Reservation
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card p-3 h-100">
                    <h4>Devices</h4>
                    <p>Manage gaming devices and device availability.</p>

                    <a asp-controller="Uredjaj" asp-action="Index" class="btn btn-primary mb-2">
                        View Devices
                    </a>

                    <a asp-controller="Uredjaj" asp-action="Create" class="btn btn-outline-primary">
                        Add Device
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card p-3 h-100">
                    <h4>Sessions</h4>
                    <p>View session history and start new user sessions.</p>

                    <a asp-controller="Sesija" asp-action="Index" class="btn btn-primary mb-2">
                        View Session History
                    </a>

                    <a asp-controller="Sesija" asp-action="Create" class="btn btn-outline-primary">
                        Start Session
                    </a>
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card p-3 h-100">
                    <h4>Payments</h4>
                    <p>Review payment history and payment methods.</p>

                    <a asp-controller="Placanje" asp-action="Index" class="btn btn-primary mb-2">
                        View Payment History
                    </a>

                    
                </div>
            </div>

            <div class="col-md-4 mb-3">
                <div class="card p-3 h-100">
                    <h4>Competitions</h4>
                    <p>View tournaments and load competitions from the external system.</p>

                    <a asp-controller="Takmicenje" asp-action="Index" class="btn btn-primary mb-2">
                        View Competitions
                    </a>

                    <a asp-controller="Home" asp-action="UcitajTakmicenja" class="btn btn-success">
                        Load Competitions
                    </a>
                </div>
            </div>

        </div>
    </div>

    @if (ViewBag.PendingUsers != null && ViewBag.PendingUsers.Count > 0)
    {
        <div class="card p-3 mb-4">
            <h4>Pending membership requests</h4>
            <p>Approve or reject registered users for the loyalty program.</p>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Membership status</th>
                        <th>Approve membership</th>
                        <th>Reject user</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in ViewBag.PendingUsers)
                    {
                        <tr>
                            <td>@user.Email</td>
                            <td>
                                <span class="badge bg-warning text-dark">
                                    Pending approval
                                </span>
                            </td>

                            <td>
                                <form asp-controller="Home" asp-action="ApproveUser" method="post">
                                    <input type="hidden" name="userId" value="@user.Id" />

                                    <button type="submit" class="btn btn-success">
                                        Approve Membership
                                    </button>
                                </form>
                            </td>

                            <td>
                                <form asp-controller="Home" asp-action="RejectUser" method="post">
                                    <input type="hidden" name="userId" value="@user.Id" />

                                    <button type="submit" class="btn btn-danger">
                                        Reject User
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No pending membership requests.
        </div>
    }
    

   
}
else if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Employee"))
{
    <h2>Employee Panel</h2>

    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card p-3 h-100">
                <h4>Users</h4>
                <p>View registered users.</p>

                <a asp-controller="Korisnik" asp-action="Index" class="btn btn-success">
                    View Users
                </a>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3 h-100">
                <h4>Reservations</h4>
                <p>View reservations and start user sessions.</p>

                <a asp-controller="Rezervacija" asp-action="Index" class="btn btn-success">
                    View Reservations
                </a>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3 h-100">
                <h4>Devices</h4>
                <p>View devices and report device issues.</p>

                <a asp-controller="Uredjaj" asp-action="Index" class="btn btn-success">
                    View Devices
                </a>
            </div>
        </div>

    </div>

    <div class="row justify-content-center my-4">

        <div class="col-md-6">
            <div class="card p-4 text-center shadow">
                <h3>Session Management</h3>

                <p>
                    Start new sessions and review active or completed sessions.
                </p>

                <a asp-controller="Sesija"
                       asp-action="Create"
                       class="btn btn-warning btn-lg mb-3 w-100">
                    Start Session
                </a>

                <a asp-controller="Sesija"
                       asp-action="Index"
                       class="btn btn-primary w-100">
                    View Sessions
                </a>
            </div>
        </div>

    </div>

    <div class="row justify-content-center">

        <div class="col-md-4">
            <div class="card p-3 text-center">
                <h4>Payments</h4>

                <p>Review payment history.</p>

                <a asp-controller="Placanje"
                       asp-action="Index"
                       class="btn btn-success">
                    View Payments
                </a>
            </div>
        </div>

    </div>

    @if (ViewBag.AktivneNarudzbe != null && ViewBag.AktivneNarudzbe.Count > 0)
    {
        <div class="card p-3 mb-4">
            <h4>Active Orders and Messages</h4>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>User</th>
                        <th>Device</th>
                        <th>Type</th>
                        <th>Content</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var n in ViewBag.AktivneNarudzbe)
                    {
                        <tr>
                            <td>@n.VrijemeSlanja.ToString("HH:mm")</td>
                            <td>@n.Korisnik?.Email</td>
                            <td>
                                @if (n.Sesija?.Uredjaj is PC pc)
                                {
                                    <span>@pc.Naziv</span>
                                }
                                else if (n.Sesija?.Uredjaj is PlayStation ps)
                                {
                                    <span>@ps.Naziv</span>
                                }
                                else if (n.Sesija?.Uredjaj is XBox xbox)
                                {
                                    <span>@xbox.Naziv</span>
                                }
                                else
                                {
                                    <span>@n.Sesija?.Uredjaj?.TipUredjaja</span>
                                }
                            </td>
                            <td>@n.Tip</td>
                            <td>
                                @if (n.Tip == TipNarudzbe.Narudzba)
                                {
                                    <span>@n.Proizvod</span>
                                }
                                else
                                {
                                    <span>@n.Poruka</span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else if (User.IsInRole("Employee"))
    {
        <div class="alert alert-info">
            No active orders or messages.
        </div>
    }
}
else if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("User"))
{
    <h2>User Panel</h2>

    @if (ViewBag.Takmicenja != null && ViewBag.Takmicenja.Count > 0)
    {
        <div class="card p-3 mb-4">
            <h3>Upcoming Gaming Tournaments</h3>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Game</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in ViewBag.Takmicenja)
                    {
                        <tr>
                            <td>@t.Naziv</td>
                            <td>@t.Igra</td>
                            <td>@t.Datum.ToString("dd.MM.yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="row justify-content-center">

        <div class="col-md-6 mb-3">
            <div class="card p-3 text-center">
                <h4>Reservations</h4>
                <p>Create and manage your reservations.</p>

                <a asp-controller="Rezervacija" asp-action="UserCreate" class="btn btn-info mb-2">
                    Add Reservation
                </a>

                <a asp-controller="Rezervacija" asp-action="Index" class="btn btn-primary">
                    My Reservations
                </a>

                @if (ViewBag.ImaAktivnuSesiju == true)
                {
                    <div class="row justify-content-center mb-3">
                        <div class="col-md-6">
                            <div class="card p-3 text-center">
                                <h4>Order or Message</h4>
                                <p>You can send an order or message while your session is active.</p>

                                <form asp-controller="Narudzba" asp-action="QuickSend" method="post">
                                    @Html.AntiForgeryToken()

                                    <div class="form-group mb-3 text-start">
                                        <label>Type</label>
                                        <select name="tip" class="form-control">
                                            <option value="Narudzba">Order</option>
                                            <option value="Poruka">Message</option>
                                        </select>
                                    </div>

                                    <div class="form-group mb-3 text-start">
                                        <label>Order</label>
                                        <input name="proizvod"
                                               class="form-control"
                                               placeholder="Example: Coffee, Coca-Cola..." />
                                    </div>

                                    <div class="form-group mb-3 text-start">
                                        <label>Message</label>
                                        <textarea name="poruka"
                                                  class="form-control"
                                                  rows="3"
                                                  placeholder="Example: I need help with my device."></textarea>
                                    </div>

                                    <button type="submit" class="btn btn-warning w-100">
                                        Send
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>

    </div>

    <div class="row justify-content-center mb-3">
        <div class="col-md-6">
            <div class="card p-3 text-center">
                <h4>Loyalty Membership</h4>

                @if (ViewBag.ClanarinaAktivna == true)
                {
                    <div class="alert alert-success">
                        Your membership has been approved.
                    </div>

                    <p>Your current loyalty points:</p>
                    <h2>@ViewBag.LoyaltyPoints</h2>
                }
                else
                {
                    <div class="alert alert-warning">
                        Your membership has not been approved by an administrator yet.
                    </div>

                    <p>You currently do not have loyalty points.</p>
                }
            </div>
        </div>
    </div>
}
else
{
    <div class="container mt-4">


        <div class="card border-0 shadow-sm mb-4 overflow-hidden">

            <div class="hero-banner text-white p-5">

                <h1 class="display-5 fw-bold">
                    GameHub Manager
                </h1>

                <p class="lead">
                    Welcome to the GameHub management system.
                    Manage devices, reservations, gaming sessions and tournaments.
                </p>

                <div>
                    <a asp-area="Identity"
                           asp-page="/Account/Register"
                           class="btn btn-light me-2">
                        Get Started
                    </a>

                    <a asp-area="Identity"
                           asp-page="/Account/Login"
                           class="btn btn-outline-light">
                        Login
                    </a>
                </div>

            </div>

        </div>

        @if (ViewBag.Takmicenja != null && ViewBag.Takmicenja.Count > 0)
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-body p-4">

                    <div class="d-flex align-items-center mb-3">
                        <h3 class="mb-0">Upcoming Gaming Tournaments</h3>
                    </div>

                    <div class="table-responsive">
                        <table class="table table-hover align-middle mb-0">
                            <thead class="table-primary">
                                <tr>
                                    <th>Name</th>
                                    <th>Game</th>
                                    <th>Date</th>
                                </tr>
                            </thead>

                            <tbody>
                                @foreach (var t in ViewBag.Takmicenja)
                                {
                                    <tr>
                                        <td>@t.Naziv</td>
                                        <td>
                                            <span class="badge bg-info text-dark">
                                                @t.Igra
                                            </span>
                                        </td>
                                        <td>@t.Datum.ToString("dd.MM.yyyy")</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>

                </div>
            </div>
        }

    </div>
}