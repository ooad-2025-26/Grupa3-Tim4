@{
    ViewData["Title"] = "Home";
}

@if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Administrator"))
{
    <h2>Administrator Panel</h2>

    <a asp-controller="Home"
           asp-action="UcitajTakmicenja"
           class="btn btn-success mb-3">
        Load competitions
    </a>

    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card p-3">
                <h4>Users</h4>
                <p>Manage user accounts, view user sessions, and review payment history.</p>

                <a asp-controller="Korisnik" asp-action="Index" class="btn btn-primary mb-2">
                    View Users
                </a>

                <a asp-controller="Korisnik" asp-action="Create" class="btn btn-outline-primary">
                    Add User
                </a>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3">
                <h4>Reservations</h4>
                <p>View, create, and manage reservations.</p>

                <a asp-controller="Rezervacija" asp-action="Index" class="btn btn-primary mb-2">
                    View Reservations
                </a>

                <a asp-controller="Rezervacija" asp-action="Create" class="btn btn-outline-primary">
                    Add Reservation
                </a>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3">
                <h4>Devices</h4>
                <p>Manage devices and monitor device issues and maintenance status.</p>

                <a asp-controller="Uredjaj" asp-action="Index" class="btn btn-primary mb-2">
                    View Devices
                </a>

                <a asp-controller="Uredjaj" asp-action="Create" class="btn btn-outline-primary">
                    Add Device
                </a>
            </div>
        </div>

    </div>

    @if (ViewBag.PendingUsers != null && ViewBag.PendingUsers.Count > 0)
    {
        <div class="card p-3 mb-4">
            <h4>Pending user requests</h4>
            <p>Approve or reject registered users and assign them a role.</p>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Approve</th>
                        <th>Reject</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var user in ViewBag.PendingUsers)
                    {
                        <tr>
                            <td>@user.Email</td>

                            <form asp-controller="Home" asp-action="ApproveUser" method="post">
                                <input type="hidden" name="userId" value="@user.Id" />

                                <td>
                                    <select name="role" class="form-select">
                                        <option value="User">User</option>
                                        <option value="Employee">Employee</option>
                                        <option value="Administrator">Administrator</option>
                                    </select>
                                </td>

                                <td>
                                    <button type="submit" class="btn btn-success">
                                        Approve
                                    </button>
                                </td>
                            </form>

                            <td>
                                <form asp-controller="Home" asp-action="RejectUser" method="post">
                                    <input type="hidden" name="userId" value="@user.Id" />

                                    <button type="submit" class="btn btn-danger">
                                        Reject
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            No pending user requests.
        </div>
    }

   
}
else if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("Employee"))
{
    <h2>Employee Panel</h2>
    <div class="row">

        <div class="col-md-4 mb-3">
            <div class="card p-3">
                <h4>Users</h4>
                <p>View registered users.</p>

                <a asp-controller="Korisnik" asp-action="Index" class="btn btn-success">
                    View Users
                </a>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3">
                <h4>Reservations</h4>
                <p>View reservations and start user sessions.</p>

                <a asp-controller="Rezervacija" asp-action="Index" class="btn btn-success">
                    View Reservations
                </a>
            </div>
        </div>

        <div class="col-md-4 mb-3">
            <div class="card p-3">
                <h4>Devices</h4>
                <p>View devices and their status.</p>

                <a asp-controller="Uredjaj" asp-action="Index" class="btn btn-success">
                    View Devices
                </a>
            </div>
        </div>

    </div>

    <div class="row justify-content-center">

        <div class="col-md-4 mb-3">
            <div class="card p-3 text-center">
                <h4>Sessions</h4>
                <p>Start a new session for a user.</p>

                <a asp-controller="Sesija"
                       asp-action="Create"
                       class="btn btn-warning">
                    Start Session
                </a>
            </div>
        </div>

    </div>
}
else if (User.Identity != null && User.Identity.IsAuthenticated && User.IsInRole("User"))
{
    <h2>User Panel</h2>

    @if (ViewBag.Takmicenja != null && ViewBag.Takmicenja.Count > 0)
    {
        <div class="card p-3 mb-4">
            <h3>Upcoming Gaming Tournaments</h3>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Game</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in ViewBag.Takmicenja)
                    {
                        <tr>
                            <td>@t.Naziv</td>
                            <td>@t.Igra</td>
                            <td>@t.Datum.ToString("dd.MM.yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }

    <div class="row justify-content-center">

        <div class="col-md-6 mb-3">
            <div class="card p-3 text-center">
                <h4>Reservations</h4>
                <p>Create a new reservation.</p>

                <a asp-controller="Rezervacija" asp-action="UserCreate" class="btn btn-info mb-2">
                    Add Reservation
                </a>
            </div>
        </div>

    </div>

    <div class="row justify-content-center mb-3">
        <div class="col-md-6">
            <div class="card p-3 text-center">
                <h4>Loyalty Points</h4>
                <p>Your current points:</p>
                <h2>@ViewBag.LoyaltyPoints</h2>
            </div>
        </div>
    </div>
}
else if (User.Identity != null && User.Identity.IsAuthenticated)
{
    <div class="alert alert-warning text-center">
        <h4>Your account is waiting for administrator approval.</h4>
        <p>Please wait until an administrator approves your account.</p>
    </div>
}
else
{
    <h1>Gaming Center System</h1>

    <p>
        Welcome to the Gaming Center System.
    </p>

    @if (ViewBag.Takmicenja != null && ViewBag.Takmicenja.Count > 0)
    {
        <div class="card p-3 mb-4">
            <h3>Upcoming Gaming Tournaments</h3>

            <table class="table table-bordered">
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Game</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in ViewBag.Takmicenja)
                    {
                        <tr>
                            <td>@t.Naziv</td>
                            <td>@t.Igra</td>
                            <td>@t.Datum.ToString("dd.MM.yyyy")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
}